{
  "name": "elfui-devtools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Developer tools for the ElfUI Custom Elements framework.",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "tsc -b packages/shared packages/runtime packages/client",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "jsdom": "27.1.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "4.0.15"
  },
  "license": "MIT"
}
